// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  fullName      String
  workEmail     String
  companyName   String
  companyWebsite String?
  phoneNumber   String?
  industry      String?
  companySize   String?
  message       String?
  status        LeadStatus @default(NEW)
  source        String?  @default("website")
  ipAddress     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workEmail])
  @@index([createdAt])
  @@index([status])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DEMO_SCHEDULED
  CLOSED
}
